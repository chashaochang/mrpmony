{
  // Replace these placeholder signing paths and passwords with your own local
  // debug/release materials before building.
  "app": {
    "products": [
      {
        "name": "default",
        "compatibleSdkVersion": "6.1.0(23)",
        "runtimeOS": "HarmonyOS",
        "targetSdkVersion": "6.1.0(23)",
        "signingConfig": "default"
      },{
        "name": "release",
        "compatibleSdkVersion": "6.1.0(23)",
        "runtimeOS": "HarmonyOS",
        "targetSdkVersion": "6.1.0(23)",
        "signingConfig": "release"
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ],
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          "certpath": "./AppScope/debug.cer",
          "keyAlias": "debugKey",
          "keyPassword": "REPLACE_ME",
          "profile": "./AppScope/debug.p7b",
          "signAlg": "SHA256withECDSA",
          "storeFile": "./AppScope/debug.p12",
          "storePassword": "REPLACE_ME"
        }
      },
      {
        "name": "release",
        "type": "HarmonyOS",
        "material": {
          "storeFile": "./AppScope/release.p12",
          "storePassword": "REPLACE_ME",
          "keyAlias": "releaseKey",
          "keyPassword": "REPLACE_ME",
          "signAlg": "SHA256withECDSA",
          "profile": "./AppScope/release.p7b",
          "certpath": "./AppScope/release.cer"
        }
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        },
        {
          "name": "release",
          "applyToProducts": [
            "release"
          ]
        }
      ]
    }
  ]
}
